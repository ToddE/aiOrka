# =============================================================================
# aiOrka — Environment Variables
# Copy this file to .env and fill in your keys. The .env file is gitignored.
# =============================================================================

# ── Cloud Provider API Keys ───────────────────────────────────────────────────
# Leave a key blank to skip that provider during integration tests.

# Anthropic (Claude models)
# https://console.anthropic.com/keys
ANTHROPIC_API_KEY=

# OpenAI (GPT / o-series models)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google Gemini
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# DeepSeek
# https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# Qwen.ai (Alibaba DashScope)
# https://dashscope.console.aliyun.com/apiKey
QWEN_API_KEY=

# ── Self-Hosted Inference Server ──────────────────────────────────────────────
# Endpoint for your self-hosted model server (Ollama, LM Studio, Msty, etc.).
# Works for local instances and tunneled/remote deployments alike.
SELFHOSTED_ENDPOINT=http://localhost:11434

# Comma-separated list of model tags available on your instance.
# Example: SELFHOSTED_MODELS=qwen3.5:9b,deepseek-r1-distill-llama-8b
SELFHOSTED_MODELS=qwen3.5:9b

# ── Integration Test Behavior ─────────────────────────────────────────────────
# Set to "true" to enable integration tests that make real API calls.
# Integration tests are skipped by default to keep CI fast.
AIORKA_INTEGRATION_TESTS=false

# Maximum time (ms) to wait for a single provider response during testing.
AIORKA_TEST_TIMEOUT_MS=10000

# Prompt used for heartbeat / smoke tests (should be minimal to save tokens).
AIORKA_TEST_PROMPT=Hello

# ── Native Library (Python / Go / Rust bindings) ──────────────────────────────
# Absolute path to the compiled shared library.
# Only needed if you're testing language bindings directly.
# AIORKA_LIB_PATH=/path/to/libaiorka.so
AIORKA_LIB_PATH=

# Set to "1" to enable native binding integration tests (Go / Rust / Python).
AIORKA_TEST_ENABLED=0

# ── Self-Hosted Authentication (optional but recommended for tunneled servers) ─
# When your self-hosted server is behind a Cloudflare Access tunnel, set these
# and reference them in aiOrka.yaml via headers_env on the provider:
#
#   headers_env:
#     CF-Access-Client-Id: CLOUDFLARE_ACCESS_ID
#     CF-Access-Client-Secret: CLOUDFLARE_ACCESS_SECRET
#
# Any arbitrary header can be injected the same way — not just Cloudflare.
CLOUDFLARE_ACCESS_ID=
CLOUDFLARE_ACCESS_SECRET=